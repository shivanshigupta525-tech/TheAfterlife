<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>The Good Place: A Museum of the Afterlife</title>
    <!-- A-Frame VR Framework -->
    <script src="https://aframe.io/releases/1.6.0/aframe.min.js"></script>
    <style>
        body { margin: 0; overflow: hidden; background-color: #f0f8ff; font-family: 'Georgia', serif; }
        
        /* Pre-VR Title Card */
        #title-card {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: #ffffff; z-index: 999; display: flex; flex-direction: column;
            justify-content: center; align-items: center; transition: opacity 3s ease-in-out;
        }
        
        #title-card h1 {
            color: #4a90e2; font-size: 2.5rem; font-weight: normal; letter-spacing: 2px;
            text-shadow: 0 4px 15px rgba(74, 144, 226, 0.2); margin-bottom: 10px;
        }
        
        #title-card p {
            color: #7f8c8d; font-style: italic; font-size: 1.2rem;
        }

        /* Subtle glowing aura */
        .aura {
            position: absolute; width: 300px; height: 300px; background: radial-gradient(circle, rgba(255,221,238,0.5) 0%, transparent 70%);
            border-radius: 50%; z-index: -1; animation: breathe 6s infinite alternate ease-in-out;
        }

        @keyframes breathe {
            0% { transform: scale(0.8); opacity: 0.5; }
            100% { transform: scale(1.2); opacity: 1; }
        }
    </style>
</head>
<body>

    <!-- Pre-VR Title Card -->
    <div id="title-card">
        <div class="aura"></div>
        <h1>The Good Place</h1>
        <p>A Museum of the Afterlife</p>
    </div>

    <script>
        // Dismiss title card after a few seconds
        window.addEventListener('load', () => {
            setTimeout(() => {
                const card = document.getElementById('title-card');
                card.style.opacity = '0';
                setTimeout(() => { card.style.display = 'none'; }, 3000);
            }, 3500);
        });

        // ==========================================
        // CUSTOM PROCEDURAL COMPONENTS FOR QUEST 3
        // ==========================================

        // Procedural Translucent Trees
        AFRAME.registerComponent('pastel-tree', {
            schema: { color: {type: 'color', default: '#ffb3ba'} },
            init: function() {
                const el = this.el;
                // Trunk
                const trunk = document.createElement('a-cylinder');
                trunk.setAttribute('radius', '0.15'); trunk.setAttribute('height', '1.5');
                trunk.setAttribute('color', '#fdfbf7'); trunk.setAttribute('position', '0 0.75 0');
                trunk.setAttribute('material', 'roughness: 0.9');
                el.appendChild(trunk);
                // Foliage
                const foliage = document.createElement('a-cone');
                foliage.setAttribute('radius-bottom', '1.2'); foliage.setAttribute('height', '2.5');
                foliage.setAttribute('color', this.data.color);
                foliage.setAttribute('emissive', this.data.color); foliage.setAttribute('emissiveIntensity', '0.4');
                foliage.setAttribute('position', '0 2.5 0');
                foliage.setAttribute('material', 'transparent: true; opacity: 0.8; roughness: 0.2');
                el.appendChild(foliage);
            }
        });

        // Procedural Clouds
        AFRAME.registerComponent('fluffy-cloud', {
            init: function() {
                const el = this.el;
                const positions = ['0 0 0', '1.5 0.5 0.5', '-1.5 0.2 -0.5', '0.8 -0.5 1', '-1 -0.2 0.8'];
                positions.forEach(pos => {
                    const puff = document.createElement('a-sphere');
                    puff.setAttribute('radius', (Math.random() * 1.5 + 1).toString());
                    puff.setAttribute('position', pos);
                    puff.setAttribute('material', 'color: #ffffff; emissive: #ffffff; emissiveIntensity: 0.1; shader: flat; transparent: true; opacity: 0.9');
                    el.appendChild(puff);
                });
                // Slow drift animation
                el.setAttribute('animation', `property: position; dir: alternate; dur: ${Math.random() * 20000 + 40000}; easing: easeInOutSine; to: ${this.el.object3D.position.x + 10} ${this.el.object3D.position.y} ${this.el.object3D.position.z}`);
            }
        });

        // Froyo Kiosk
        AFRAME.registerComponent('froyo-shop', {
            schema: { name: {type: 'string', default: 'Froyo'}, color: {type: 'color', default: '#ffb3ba'}, flavor: {type: 'string'} },
            init: function() {
                const el = this.el;
                // Base
                const base = document.createElement('a-cylinder');
                base.setAttribute('radius', '1.5'); base.setAttribute('height', '1');
                base.setAttribute('color', '#ffffff'); base.setAttribute('position', '0 0.5 0');
                el.appendChild(base);
                // Awning/Top
                const top = document.createElement('a-cone');
                top.setAttribute('radius-bottom', '1.8'); top.setAttribute('height', '1');
                top.setAttribute('color', this.data.color); top.setAttribute('position', '0 1.5 0');
                el.appendChild(top);
                // Giant Froyo swirl (stacked spheres)
                const froyo = document.createElement('a-sphere');
                froyo.setAttribute('radius', '0.6'); froyo.setAttribute('color', this.data.color);
                froyo.setAttribute('emissive', this.data.color); froyo.setAttribute('emissiveIntensity', '0.5');
                froyo.setAttribute('position', '0 2.2 0');
                froyo.setAttribute('scale', '1 0.8 1');
                el.appendChild(froyo);
                
                // Interaction hit box
                const hitBox = document.createElement('a-cylinder');
                hitBox.setAttribute('radius', '2'); hitBox.setAttribute('height', '4');
                hitBox.setAttribute('material', 'visible: false');
                hitBox.setAttribute('class', 'clickable');
                
                // Flavor Text
                const text = document.createElement('a-text');
                text.setAttribute('value', this.data.flavor); text.setAttribute('align', 'center');
                text.setAttribute('position', '0 3.2 0'); text.setAttribute('scale', '1.5 1.5 1.5');
                text.setAttribute('color', '#333333'); text.setAttribute('visible', 'false');
                text.setAttribute('font', 'kelsonsans');
                
                hitBox.addEventListener('mouseenter', () => {
                    text.setAttribute('visible', 'true');
                    if(el.components.sound) el.components.sound.playSound();
                    triggerHaptic(0.5, 50);
                });
                hitBox.addEventListener('mouseleave', () => { text.setAttribute('visible', 'false'); });
                
                el.appendChild(hitBox);
                el.appendChild(text);
            }
        });

        // Teleportation Logic
        AFRAME.registerComponent('teleport-node', {
            init: function() {
                this.el.addEventListener('click', () => {
                    const rig = document.getElementById('rig');
                    const camFade = document.getElementById('cam-fade');
                    const targetPos = this.el.getAttribute('position');
                    
                    // Trigger Haptic
                    triggerHaptic(1.0, 100);

                    // Fade out
                    camFade.setAttribute('animation', 'property: material.opacity; to: 1; dur: 250; easing: easeOutQuad');
                    setTimeout(() => {
                        // Move rig
                        rig.setAttribute('position', {x: targetPos.x, y: 0, z: targetPos.z});
                        // Fade in
                        camFade.setAttribute('animation', 'property: material.opacity; to: 0; dur: 400; easing: easeInQuad');
                    }, 250);
                });
                
                // Visual feedback on hover
                this.el.addEventListener('mouseenter', () => {
                    this.el.setAttribute('animation__scale', 'property: scale; to: 1.2 1.2 1.2; dur: 200');
                    this.el.setAttribute('material', 'emissiveIntensity', '0.8');
                    triggerHaptic(0.2, 30);
                });
                this.el.addEventListener('mouseleave', () => {
                    this.el.setAttribute('animation__scale', 'property: scale; to: 1 1 1; dur: 200');
                    this.el.setAttribute('material', 'emissiveIntensity', '0.4');
                });
            }
        });

        // Intro Text Fade
        AFRAME.registerComponent('fade-intro', {
            init: function() {
                setTimeout(() => {
                    this.el.setAttribute('animation', 'property: components.text.material.uniforms.opacity.value; to: 0; dur: 4000; easing: easeOutQuad');
                    this.el.setAttribute('animation__move', 'property: position; to: 0 3 -4; dur: 4000; easing: easeOutQuad');
                }, 3000);
            }
        });

        // Memory Pebble Interaction
        AFRAME.registerComponent('memory-pebble', {
            init: function() {
                this.el.addEventListener('mouseenter', () => {
                    this.el.setAttribute('animation__glow', 'property: material.emissiveIntensity; to: 1; dur: 300');
                    if(this.el.components.sound) this.el.components.sound.playSound();
                    triggerHaptic(0.4, 80);
                });
                this.el.addEventListener('mouseleave', () => {
                    this.el.setAttribute('animation__glow', 'property: material.emissiveIntensity; to: 0.4; dur: 500');
                });
            }
        });

        // Haptics Helper
        function triggerHaptic(intensity, duration) {
            const rightHand = document.getElementById('right-hand');
            if (rightHand && rightHand.components.haptics) {
                rightHand.components.haptics.pulse(intensity, duration);
            }
        }
    </script>

    <!-- 
      SCENE SETUP
      Background is sky blue. Fog creates the infinite depth and merges with the pink lighting.
      No physics, no WASD.
    -->
    <a-scene 
        renderer="antialias: true; colorManagement: true;"
        background="color: #6bb9f0"
        fog="type: exponential; color: #ffffff; density: 0.025"
        cursor="rayOrigin: mouse">

        <a-assets>
            <!-- Audio Placeholders (Using A-Frame default for standalone compatibility) -->
            <!-- In production, these would be specific warm pads and chimes -->
            <audio id="snd-ambient" src="https://cdn.aframe.io/basic-guide/audio/backgroundnoise.wav" preload="auto"></audio>
            <audio id="snd-chime" src="https://cdn.aframe.io/basic-guide/audio/backgroundnoise.wav" preload="auto"></audio>
            <audio id="snd-waterfall" src="https://cdn.aframe.io/basic-guide/audio/backgroundnoise.wav" preload="auto"></audio>
            
            <a-mixin id="teleport-ring" geometry="primitive: torus; radius: 1; radiusTubular: 0.05" material="shader: flat; color: #ffffff; emissive: #ffffff; emissiveIntensity: 0.4; transparent: true; opacity: 0.8" class="clickable" teleport-node></a-mixin>
            <a-mixin id="pebble-mat" material="shader: standard; color: #ffffff; roughness: 0.2; metalness: 0.1; transparent: true; opacity: 0.9; side: double"></a-mixin>
        </a-assets>

        <!-- RIG & CONTROLS -->
        <a-entity id="rig" position="0 0 0">
            <a-entity camera position="0 1.6 0" look-controls="pointerLockEnabled: false">
                <!-- Fade Overlay for Teleportation -->
                <a-plane id="cam-fade" position="0 0 -0.1" material="color: #ffffff; shader: flat; transparent: true; opacity: 0; side: double" scale="2 2 1"></a-plane>
            </a-entity>
            <!-- Laser controls for interaction -->
            <a-entity id="left-hand" laser-controls="hand: left" raycaster="objects: .clickable" haptics></a-entity>
            <a-entity id="right-hand" laser-controls="hand: right" raycaster="objects: .clickable" haptics></a-entity>
            
            <!-- Global Harmonic Ambient Bed -->
            <a-sound src="#snd-ambient" autoplay="true" loop="true" volume="0.2"></a-sound>
        </a-entity>

        <!-- ========================================== -->
        <!-- LIGHTING (THE PINK LIGHT PRINCIPLE)        -->
        <!-- ========================================== -->
        <!-- No visible sun. Omnidirectional soft pink-tinted illumination -->
        <a-light type="ambient" color="#ffddee" intensity="0.65"></a-light>
        <a-light type="hemisphere" color="#ffffff" groundColor="#ffbbee" intensity="0.5"></a-light>

        <!-- ========================================== -->
        <!-- THE LANDSCAPE                              -->
        <!-- ========================================== -->
        
        <!-- The Grass (Infinite glowing meadow) -->
        <a-plane rotation="-90 0 0" scale="300 300 1" material="shader: standard; color: #a8e6cf; emissive: #a8e6cf; emissiveIntensity: 0.1; roughness: 1; metalness: 0"></a-plane>

        <!-- The Sky Clouds -->
        <a-entity position="0 30 -50">
            <a-entity fluffy-cloud position="-20 0 0" scale="2 2 2"></a-entity>
            <a-entity fluffy-cloud position="15 5 -10" scale="3 1.5 3"></a-entity>
            <a-entity fluffy-cloud position="0 -5 15" scale="2.5 2 2.5"></a-entity>
            <a-entity fluffy-cloud position="-35 10 -20" scale="4 2 4"></a-entity>
            <a-entity fluffy-cloud position="40 0 5" scale="2 2 2"></a-entity>
        </a-entity>

        <!-- Waterfall & Rainbow (Central Vista) -->
        <a-entity position="0 0 -40">
            <!-- Glowing Cliff/Backdrop -->
            <a-cylinder position="0 15 -5" radius="15" height="30" theta-start="180" theta-length="180" material="color: #e0f2f1; emissive: #e0f2f1; emissiveIntensity: 0.1"></a-cylinder>
            
            <!-- Waterfall Surface -->
            <a-plane position="0 15 0" rotation="0 0 0" width="8" height="30" 
                     material="shader: standard; color: #81d4fa; emissive: #4fc3f7; emissiveIntensity: 0.5; transparent: true; opacity: 0.8"
                     animation="property: material.emissiveIntensity; from: 0.4; to: 0.7; dur: 2000; dir: alternate; loop: true"></a-plane>
            
            <!-- Mist at base -->
            <a-entity particle-system="preset: dust; color: #ffffff, #b3e5fc; particleCount: 500; size: 2" position="0 0 1"></a-entity>
            <a-sound src="#snd-waterfall" autoplay="true" loop="true" volume="0.4" positional="true"></a-sound>

            <!-- The Rainbow (Tangent arcs) -->
            <a-entity position="0 0 15" rotation="0 0 0">
                <a-torus radius="20" radius-tubular="0.4" arc="180" material="shader: flat; color: #ffadad; transparent: true; opacity: 0.4; side: double"></a-torus>
                <a-torus radius="19.5" radius-tubular="0.4" arc="180" material="shader: flat; color: #fdffb6; transparent: true; opacity: 0.4; side: double"></a-torus>
                <a-torus radius="19" radius-tubular="0.4" arc="180" material="shader: flat; color: #caffbf; transparent: true; opacity: 0.4; side: double"></a-torus>
                <a-torus radius="18.5" radius-tubular="0.4" arc="180" material="shader: flat; color: #9bf6ff; transparent: true; opacity: 0.4; side: double"></a-torus>
            </a-entity>
        </a-entity>

        <!-- The Forest (Translucent Trees) -->
        <!-- Left flank -->
        <a-entity position="-15 0 -10">
            <a-entity pastel-tree="color: #ffadad" position="0 0 0"></a-entity>
            <a-entity pastel-tree="color: #fdffb6" position="-3 0 -4"></a-entity>
            <a-entity pastel-tree="color: #caffbf" position="2 0 -6" scale="1.5 1.5 1.5"></a-entity>
            <a-entity pastel-tree="color: #9bf6ff" position="-6 0 2" scale="0.8 0.8 0.8"></a-entity>
            <a-entity pastel-tree="color: #bdb2ff" position="4 0 3"></a-entity>
        </a-entity>
        <!-- Right flank -->
        <a-entity position="18 0 -15">
            <a-entity pastel-tree="color: #caffbf" position="0 0 0" scale="1.2 1.2 1.2"></a-entity>
            <a-entity pastel-tree="color: #bdb2ff" position="3 0 -3"></a-entity>
            <a-entity pastel-tree="color: #ffadad" position="-2 0 4" scale="0.9 0.9 0.9"></a-entity>
            <a-entity pastel-tree="color: #9bf6ff" position="5 0 2"></a-entity>
        </a-entity>
        <!-- Background Filler -->
        <a-entity pastel-tree="color: #fdffb6" position="25 0 -30" scale="2 2 2"></a-entity>
        <a-entity pastel-tree="color: #ffadad" position="-28 0 -25" scale="1.8 1.8 1.8"></a-entity>

        <!-- ========================================== -->
        <!-- EASTER EGGS & STRUCTURES                   -->
        <!-- ========================================== -->

        <!-- Start Opening Text -->
        <a-entity id="intro-text" text="value: It's all connected.; font: kelsonsans; color: #ffffff; align: center; width: 8; opacity: 1" position="0 2.5 -3" fade-intro></a-entity>

        <!-- 1. The Icelandic Primitive Cottage -->
        <a-entity position="-10 0 2" rotation="0 45 0">
            <!-- Cottage Body -->
            <a-box width="3" height="2" depth="3" position="0 1 0" material="color: #8c7b70; roughness: 0.9"></a-box>
            <!-- Sod Roof -->
            <a-cone radius-bottom="2.5" height="1.5" position="0 2.75 0" material="color: #6a8a5c; roughness: 1"></a-cone>
            <!-- Ajar Window/Door opening -->
            <a-plane width="1" height="1.2" position="0 0.8 1.51" material="color: #3e3630"></a-plane>
            <!-- The Clown Painting Joke (inside) -->
            <a-entity position="0 1 1.4">
                <!-- Abstract clown face elements glowing faintly -->
                <a-circle radius="0.3" position="0 0.2 -0.5" material="color: #ffffff; emissive: #ffffff; emissiveIntensity: 0.2"></a-circle>
                <a-sphere radius="0.08" position="0 0.2 -0.45" material="color: #ff0000; emissive: #ff0000; emissiveIntensity: 0.8"></a-sphere>
            </a-entity>
            <!-- Hidden sting sound when peeking (proximity raycast box) -->
            <a-box width="2" height="2" depth="2" position="0 1 1.5" material="visible: false" class="clickable" sound="src: #snd-chime; on: mouseenter; volume: 0.3"></a-box>
        </a-entity>

        <!-- 2. Tahani's Mansion (Distant Illusion) -->
        <a-entity position="40 10 -40" rotation="0 -30 0" scale="2 2 2">
            <a-box width="10" height="4" depth="4" material="color: #ffffff; emissive: #ffffff; emissiveIntensity: 0.1"></a-box>
            <a-cylinder position="-4 0 2.5" radius="0.2" height="4" material="color: #ffffff"></a-cylinder>
            <a-cylinder position="-2 0 2.5" radius="0.2" height="4" material="color: #ffffff"></a-cylinder>
            <a-cylinder position="0 0 2.5" radius="0.2" height="4" material="color: #ffffff"></a-cylinder>
            <a-cylinder position="2 0 2.5" radius="0.2" height="4" material="color: #ffffff"></a-cylinder>
            <a-cylinder position="4 0 2.5" radius="0.2" height="4" material="color: #ffffff"></a-cylinder>
            <!-- Glowing fountain proxy -->
            <a-sphere position="0 -2 8" radius="1" material="color: #81d4fa; emissive: #4fc3f7; emissiveIntensity: 0.6"></a-sphere>
        </a-entity>

        <!-- 3. The Frozen Yogurt Grove -->
        <a-entity position="12 0 -5" rotation="0 -20 0" sound="src: #snd-chime; on: froyo-hover; poolSize: 3">
            <a-entity froyo-shop="flavor: Swirl of Contentment; color: #ffadad" position="-4 0 0"></a-entity>
            <a-entity froyo-shop="flavor: Froyo-dice; color: #caffbf" position="0 0 -2"></a-entity>
            <a-entity froyo-shop="flavor: The Yogurt of Enlightenment; color: #9bf6ff" position="4 0 0"></a-entity>
        </a-entity>

        <!-- 4. Neighborhood Architect's Office -->
        <a-entity position="-15 0 -20" rotation="0 60 0">
            <!-- Mid-century structure -->
            <a-box width="6" height="0.2" depth="5" position="0 0.1 0" material="color: #8B5A2B"></a-box>
            <a-box width="6" height="0.2" depth="5" position="0 3 0" material="color: #8B5A2B"></a-box>
            <!-- Glass walls -->
            <a-box width="5.8" height="2.8" depth="4.8" position="0 1.5 0" material="color: #aaddff; transparent: true; opacity: 0.2; roughness: 0.1; metalness: 0.8"></a-box>
            <!-- Interior Desk & Chair -->
            <a-box width="2" height="0.8" depth="1" position="0 0.5 0" material="color: #5c4033"></a-box>
            <a-box width="0.8" height="1.2" depth="0.8" position="0 0.6 -1" material="color: #1a1a1a"></a-box>
        </a-entity>

        <!-- ========================================== -->
        <!-- EMOTIONAL ZONES (HEADSPACE)                -->
        <!-- ========================================== -->

        <!-- Zone A: Grove of Good Memories -->
        <a-entity position="-5 0 -12">
            <a-entity pastel-tree="color: #ffd6a5" position="0 0 0" scale="1.5 1.5 1.5"></a-entity>
            <!-- Memory Pebbles -->
            <a-entity position="0 1.5 1" sound="src: #snd-chime; poolSize: 4">
                <a-sphere mixin="pebble-mat" radius="0.15" position="-1 1 0" material="emissive: #ffd6a5; emissiveIntensity: 0.4" class="clickable" memory-pebble
                    animation="property: position; dir: alternate; dur: 3000; loop: true; to: -1 1.1 0"></a-sphere>
                <a-sphere mixin="pebble-mat" radius="0.1" position="0.5 0.5 0.5" material="emissive: #fdffb6; emissiveIntensity: 0.4" class="clickable" memory-pebble
                    animation="property: position; dir: alternate; dur: 4000; loop: true; to: 0.5 0.6 0.5"></a-sphere>
                <a-sphere mixin="pebble-mat" radius="0.2" position="1 1.2 -0.5" material="emissive: #ffadad; emissiveIntensity: 0.4" class="clickable" memory-pebble
                    animation="property: position; dir: alternate; dur: 3500; loop: true; to: 1 1.3 -0.5"></a-sphere>
            </a-entity>
        </a-entity>

        <!-- Zone B: Pool of Reflecting Dreams -->
        <a-entity position="8 0.05 -18">
            <a-circle radius="4" rotation="-90 0 0" material="color: #e0f7fa; roughness: 0; metalness: 0.9; transparent: true; opacity: 0.8"></a-circle>
            <!-- Inflatable dream clouds on surface -->
            <a-sphere radius="0.8" position="-1 0.2 -1" scale="1 0.4 1" material="color: #ffffff; shader: flat; transparent: true; opacity: 0.7"
                animation="property: position; to: 1 0.2 1; dur: 15000; dir: alternate; loop: true"></a-sphere>
            <a-sphere radius="0.6" position="1.5 0.2 0" scale="1 0.4 1" material="color: #fce4ec; shader: flat; transparent: true; opacity: 0.7"
                animation="property: position; to: -1.5 0.2 -0.5; dur: 18000; dir: alternate; loop: true"></a-sphere>
        </a-entity>

        <!-- Zone C: Path of Intention (Inhibitions Curtain) -->
        <a-entity position="0 0 -8">
            <a-plane width="6" height="4" position="0 2 0" material="color: #ffffff; emissive: #ffffff; emissiveIntensity: 0.1; transparent: true; opacity: 0.15; side: double; depthWrite: false"></a-plane>
            <a-plane width="6" height="4" position="0 2 -0.2" material="color: #ffdde1; emissive: #ffdde1; emissiveIntensity: 0.1; transparent: true; opacity: 0.15; side: double; depthWrite: false"></a-plane>
        </a-entity>

        <!-- Zone D: The Core (Central Chat) -->
        <a-entity position="0 0 -22">
            <!-- Circular Platform -->
            <a-cylinder radius="3" height="0.1" position="0 0 0" material="color: #e0f2f1; emissive: #e0f2f1; emissiveIntensity: 0.2"></a-cylinder>
            
            <!-- Overstuffed Armchair (Facing waterfall) -->
            <a-entity position="0 0.5 0.5" rotation="0 180 0">
                <!-- Seat -->
                <a-box width="1" height="0.4" depth="1" position="0 0 0" material="color: #6a8a5c; roughness: 0.8"></a-box>
                <!-- Back -->
                <a-box width="1" height="1" depth="0.3" position="0 0.7 -0.35" material="color: #6a8a5c; roughness: 0.8"></a-box>
                <!-- Arms -->
                <a-box width="0.3" height="0.6" depth="1" position="-0.65 0.3 0" material="color: #6a8a5c; roughness: 0.8"></a-box>
                <a-box width="0.3" height="0.6" depth="1" position="0.65 0.3 0" material="color: #6a8a5c; roughness: 0.8"></a-box>
            </a-entity>

            <!-- The Silhouettes (Pure warm radiance) -->
            <a-entity position="-2 0 -1">
                <a-cylinder radius="0.3" height="1.6" position="0 0.8 0" material="shader: flat; color: #fff8e7; transparent: true; opacity: 0.8"></a-cylinder>
                <a-sphere radius="0.25" position="0 1.7 0" material="shader: flat; color: #fff8e7; transparent: true; opacity: 0.9"></a-sphere>
            </a-entity>
            <a-entity position="1.5 0 -1.5">
                <a-cylinder radius="0.25" height="1.5" position="0 0.75 0" material="shader: flat; color: #fff8e7; transparent: true; opacity: 0.7"></a-cylinder>
                <a-sphere radius="0.2" position="0 1.6 0" material="shader: flat; color: #fff8e7; transparent: true; opacity: 0.8"></a-sphere>
            </a-entity>
            
            <!-- Heartbeat rhythm at the core -->
            <a-sound src="#snd-ambient" volume="0.3" positional="true" loop="true"></a-sound>
        </a-entity>


        <!-- ========================================== -->
        <!-- NAVIGATION (TELEPORT NODES)                -->
        <!-- ========================================== -->
        <!-- Start Node -->
        <a-entity position="0 0.05 0" mixin="teleport-ring"></a-entity>
        
        <!-- Cross path -->
        <a-entity position="0 0.05 -5" mixin="teleport-ring"></a-entity>

        <!-- Cottage View -->
        <a-entity position="-6 0.05 -2" mixin="teleport-ring"></a-entity>

        <!-- Froyo Grove -->
        <a-entity position="6 0.05 -3" mixin="teleport-ring"></a-entity>

        <!-- Architect & Memories -->
        <a-entity position="-6 0.05 -15" mixin="teleport-ring"></a-entity>

        <!-- Reflecting Pool -->
        <a-entity position="4 0.05 -15" mixin="teleport-ring"></a-entity>

        <!-- The Core Viewpoint -->
        <a-entity position="0 0.05 -18" mixin="teleport-ring"></a-entity>

    </a-scene>
</body>
